-- 5. LÓGICA CORE (AIMBOT / ESP)
--- --- ---

RunService.RenderStepped:Connect(function()
    local cam = workspace.CurrentCamera
    local mousePos = UserInputService:GetMouseLocation()
    fovFrame.Visible = states.fovVisible
    fovFrame.Position = UDim2.new(0, mousePos.X, 0, mousePos.Y)
    if states.aimbot or states.silentAim then
        local target = nil
        local closest3DDist = 250
        local myChar = player.Character
        local myRoot = myChar and (myChar:FindFirstChild("HumanoidRootPart") or myChar:FindFirstChild("Head"))
        if myRoot then
            for _, p in pairs(Players:GetPlayers()) do
                local isEnemy = true
                if states.teamCheck and player.Team and p.Team == player.Team then isEnemy = false end
                if p ~= player and isEnemy and p.Character then
                    local hum = p.Character:FindFirstChild("Humanoid")
                    local targetPartName = (states.aimTarget == "Head") and "Head" or (p.Character:FindFirstChild("UpperTorso") and "UpperTorso" or "HumanoidRootPart")
                    local targetPart = p.Character:FindFirstChild(targetPartName)
                    if hum and hum.Health > 0 and targetPart then
                        local pos, vis = cam:WorldToViewportPoint(targetPart.Position)
                        if vis then
                            local mDist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                            if mDist < states.fovSize then 
                                local realDist = (myRoot.Position - targetPart.Position).Magnitude
                                if realDist < closest3DDist then 
                                    closest3DDist = realDist; target = targetPart 
                                end
                            end
                        end
                    end
                end
            end
        end
        if target then 
            if states.silentAim then
                if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then cam.CFrame = CFrame.lookAt(cam.CFrame.Position, target.Position) end
            elseif states.aimbot then cam.CFrame = CFrame.lookAt(cam.CFrame.Position, target.Position) end
        end
    end
end)

-- (Arraste e Tecla G continuam os mesmos)
UserInputService.InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == Enum.KeyCode.G and not isAnimating then
        isMenuOpen = not isMenuOpen
        if isMenuOpen then
            mainFrame.Visible = true
            TweenService:Create(mainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0.5, -250, 0.5, -175)}):Play()
        else
            local t = TweenService:Create(mainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Position = UDim2.new(0.5, -250, 1.5, 0)})
            t:Play(); t.Completed:Connect(function() mainFrame.Visible = false end)
        end
    end
end)

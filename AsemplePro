-- 3. LÓGICA CORE (AIMBOT)
--- --- ---

RunService.RenderStepped:Connect(function()
    local cam = workspace.CurrentCamera
    local mousePos = UserInputService:GetMouseLocation()

    fovFrame.Visible = states.fovVisible
    fovFrame.Position = UDim2.new(0, mousePos.X, 0, mousePos.Y)

    if states.aimbot or states.silentAim then
        local target = nil
        local closest3DDist = 250
        
        local myChar = player.Character
        local myRoot = myChar and (myChar:FindFirstChild("HumanoidRootPart") or myChar:FindFirstChild("Head"))
        
        if myRoot then
            for _, p in pairs(Players:GetPlayers()) do
                local isEnemy = true
                if states.teamCheck and player.Team and p.Team == player.Team then isEnemy = false end
                
                if p ~= player and isEnemy and p.Character then
                    local hum = p.Character:FindFirstChild("Humanoid")
                    local targetPartName = (states.aimTarget == "Head") and "Head" or (p.Character:FindFirstChild("UpperTorso") and "UpperTorso" or "HumanoidRootPart")
                    local targetPart = p.Character:FindFirstChild(targetPartName)

                    if hum and hum.Health > 0 and targetPart then
                        local pos, vis = cam:WorldToViewportPoint(targetPart.Position)
                        if vis then
                            local mDist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                            if mDist < states.fovSize then 
                                local realDist = (myRoot.Position - targetPart.Position).Magnitude
                                if realDist < closest3DDist then 
                                    closest3DDist = realDist
                                    target = targetPart 
                                end
                            end
                        end
                    end
                end
            end
        end
        
        if target then 
            if states.silentAim then
                if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
                    cam.CFrame = CFrame.lookAt(cam.CFrame.Position, target.Position)
                end
            elseif states.aimbot then
                cam.CFrame = CFrame.lookAt(cam.CFrame.Position, target.Position)
            end
        end
    end
end)

RunService.Heartbeat:Connect(function()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local visual = p.Character:FindFirstChild("Asmp")
            if states.esp then
                local root = p.Character:FindFirstChild("HumanoidRootPart") or p.Character:FindFirstChild("Head")
                if root and not visual then
                    local f = Instance.new("Folder", p.Character); f.Name = "Asmp"
                    local bb = Instance.new("BillboardGui", f); bb.Adornee = root; bb.Size = UDim2.new(4,0,5,0); bb.AlwaysOnTop = true
                    local b = Instance.new("Frame", bb); b.Size = UDim2.new(1,0,1,0); b.BackgroundTransparency = 1
                    local s = Instance.new("UIStroke", b); s.Thickness = 2; s.Color = Color3.fromRGB(0, 191, 255)
                end
            elseif visual then visual:Destroy() end
        end
    end
end)


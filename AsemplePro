local orderCount = 0
local function AddCategory(name)
    orderCount = orderCount + 1
    local frame = Instance.new("Frame", container)
    frame.Size = UDim2.new(1, 0, 0, 25); frame.BackgroundTransparency = 1; frame.LayoutOrder = orderCount
    local lbl = Instance.new("TextLabel", frame)
    lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1
    lbl.Text = string.upper(name); lbl.TextColor3 = Color3.fromRGB(0, 191, 255)
    lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 12; lbl.TextXAlignment = Enum.TextXAlignment.Left
end

local function CreateSwitch(name, key)
    orderCount = orderCount + 1
    local frame = Instance.new("Frame", container)
    frame.Size = UDim2.new(1, -10, 0, 40); frame.BackgroundColor3 = Color3.fromRGB(22, 22, 22); frame.LayoutOrder = orderCount
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, -60, 1, 0); label.Position = UDim2.new(0, 15, 0, 0); label.BackgroundTransparency = 1
    label.Text = name; label.TextColor3 = Color3.fromRGB(200, 200, 200); label.Font = Enum.Font.GothamMedium; label.TextSize = 13; label.TextXAlignment = Enum.TextXAlignment.Left
    local switchBG = Instance.new("TextButton", frame)
    switchBG.Size = UDim2.new(0, 36, 0, 18); switchBG.Position = UDim2.new(1, -45, 0.5, -9); switchBG.BackgroundColor3 = states[key] and Color3.fromRGB(0, 191, 255) or Color3.fromRGB(40, 40, 40); switchBG.Text = ""
    Instance.new("UICorner", switchBG).CornerRadius = UDim.new(1, 0)
    local knob = Instance.new("Frame", switchBG)
    knob.Size = UDim2.new(0, 14, 0, 14); knob.Position = states[key] and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7); knob.BackgroundColor3 = Color3.new(1,1,1); Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    switchBG.MouseButton1Click:Connect(function()
        states[key] = not states[key]
        local active = states[key]
        TweenService:Create(knob, TweenInfo.new(0.2), {Position = active and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}):Play()
        TweenService:Create(switchBG, TweenInfo.new(0.2), {BackgroundColor3 = active and Color3.fromRGB(0, 191, 255) or Color3.fromRGB(40, 40, 40)}):Play()
    end)
end

local function CreateModeSelector(name, key, opt1, opt2)
    orderCount = orderCount + 1
    local frame = Instance.new("Frame", container)
    frame.Size = UDim2.new(1, -10, 0, 40); frame.BackgroundColor3 = Color3.fromRGB(22, 22, 22); frame.LayoutOrder = orderCount
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, -100, 1, 0); label.Position = UDim2.new(0, 15, 0, 0); label.BackgroundTransparency = 1
    label.Text = name; label.TextColor3 = Color3.fromRGB(200, 200, 200); label.Font = Enum.Font.GothamMedium; label.TextSize = 13; label.TextXAlignment = Enum.TextXAlignment.Left
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(0, 80, 0, 24); btn.Position = UDim2.new(1, -90, 0.5, -12); btn.BackgroundColor3 = Color3.fromRGB(0, 191, 255); btn.Text = states[key]
    btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.GothamBold; btn.TextSize = 12; Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    btn.MouseButton1Click:Connect(function() states[key] = (states[key] == opt1) and opt2 or opt1; btn.Text = states[key] end)
end

local function CreateSlider(name)
    orderCount = orderCount + 1
    local frame = Instance.new("Frame", container)
    frame.Size = UDim2.new(1, -10, 0, 50); frame.BackgroundTransparency = 1; frame.LayoutOrder = orderCount
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, 0, 0, 20); label.Text = name .. ": " .. states.fovSize; label.TextColor3 = Color3.fromRGB(200, 200, 200); label.BackgroundTransparency = 1; label.Font = Enum.Font.Gotham; label.TextSize = 12; label.TextXAlignment = Enum.TextXAlignment.Left
    local bar = Instance.new("TextButton", frame)
    bar.Size = UDim2.new(1, 0, 0, 4); bar.Position = UDim2.new(0, 0, 0, 25); bar.BackgroundColor3 = Color3.fromRGB(45, 45, 45); bar.Text = ""; Instance.new("UICorner", bar)
    local fill = Instance.new("Frame", bar)
    fill.Size = UDim2.new(states.fovSize/600, 0, 1, 0); fill.BackgroundColor3 = Color3.fromRGB(0, 191, 255); Instance.new("UICorner", fill)
    bar.MouseButton1Down:Connect(function()
        local move; move = RunService.RenderStepped:Connect(function()
            local rel = math.clamp((UserInputService:GetMouseLocation().X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
            fill.Size = UDim2.new(rel, 0, 1, 0); states.fovSize = math.floor(rel * 600); label.Text = name .. ": " .. states.fovSize
            fovFrame.Size = UDim2.new(0, states.fovSize * 2, 0, states.fovSize * 2)
        end)
        local release; release = UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then move:Disconnect(); release:Disconnect() end end)
    end)
end

